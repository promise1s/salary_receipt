{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:start": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "dist": "npm run build && electron-builder --mac dmg",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.salary.receipt",
    "productName": "薪资计算器",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "mac": {
      "icon": "icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.finance",
      "electronLanguages": [
        "en",
        "zh_CN"
      ]
    },
    "dmg": {
      "title": "薪资计算器",
      "artifactName": "SalaryReceipt-${version}.dmg",
      "window": {
        "width": 640,
        "height": 420
      },
      "iconSize": 128,
      "contents": [
        {
          "x": 170,
          "y": 220,
          "type": "file"
        },
        {
          "x": 470,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "electron-server.cjs",
      "public/**/*",
      "icon.icns",
      "package.json",
      "!**/*.cjson",
      "!**/*.map",
      "!**/node_modules/**/*.md",
      "!**/node_modules/**/*.txt",
      "!**/node_modules/**/test/**",
      "!**/node_modules/**/tests/**"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "npmRebuild": true
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.4"
  }
}